{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./run-dev.mjs",
    "build": "node ./build.mjs",
    "build:all": "BASE_PATH=/admin pnpm --filter @workspace/fellowship-exam run build && node ./build.mjs",
    "start": "node --enable-source-maps --env-file=.env ./dist/index.mjs",
    "start:prod": "NODE_ENV=production node --enable-source-maps --env-file=.env ./dist/index.mjs",
    "prod": "pnpm run build:all && pnpm run start:prod",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "node ./build-seed.mjs && node ./dist/seed.mjs"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@types/nodemailer": "^8.0.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "pino": "^9",
    "pino-http": "^10",
    "razorpay": "^2.9.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/pdfkit": "^0.17.6",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
